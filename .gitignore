# Root-level ignores. Per-app .gitignore lives at apps/{blog,website}/.gitignore
.DS_Store
*.log
.env
.env.local
.env.*.local
.idea/
.vscode/
*.swp
*.swo
~$*
Thumbs.db
.cache/

# Local wrangler state (per-machine CF auth, do not commit)
.wrangler/

# Playwright MCP screenshot/snapshot output (per-session scratch, do not commit)
.playwright-mcp/

# Local staging dir for website deploy (recreated each deploy run)
_stage_website/

# Claude Code harness — keep only settings.json tracked, ignore rest (skills/agents/commands/hooks/logs/memory/metrics/progress)
.claude/*
!.claude/settings.json
# Agent Skills universal install dir (npx skills add → kepano/obsidian-skills etc.); per-machine, do not commit
.agents/
apps/blog/.claude/*
!apps/blog/.claude/settings.json
