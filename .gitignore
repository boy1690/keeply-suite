# ===========================
# Dev tooling (local only, NOT pushed to remote)
# Note: /_dev/ is TRACKED because GitHub Actions runs `npm run build` which
# executes scripts inside it (spec 021). Only ad-hoc / temporary files in
# /_dev/ remain ignored.
# ===========================
/_dev/_tmp*
/_dev/baseline.css
/_dev/verify.css
CLAUDE.md
.claude/
.specify/
specs/
idea/
0.idea/
*.log
.tmp/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/
# package.json + package-lock.json tracked (required by GitHub Actions npm ci; spec 021 CI)

# Translation build artifacts
i18n/translation-template.md
i18n/*.zip
i18n/_*.cjs
i18n/_*.js
.playwright-mcp/
fonts/_full-backup/

# Fingerprint manifest (spec 15) — regenerated every build.
fingerprint-manifest.json

# Spec 36: hashed JS build artifacts are regenerated by CI on every deploy
# (committing them is dead weight; CI cleanup step also wipes them).
/*.[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].js
/i18n/*.[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].js

# Spec 36: locale pack intermediates — build-fingerprint.js synthesizes
# pack `.js` content in memory from `i18n/*.json` and emits only the hashed
# variant. The unhashed `i18n/<locale>.js` should never appear in git.
# (Pattern below is narrower than the existing `i18n/_*.js` rule so it
# doesn't accidentally match `i18n/_some-tool.js`.)
/i18n/zh-TW.js
/i18n/zh-CN.js
/i18n/en.js
/i18n/ja.js
/i18n/ko.js
/i18n/de.js
/i18n/fr.js
/i18n/es.js
/i18n/pt.js
/i18n/it.js
/i18n/nl.js
/i18n/pl.js
/i18n/cs.js
/i18n/hu.js
/i18n/tr.js
/i18n/fi.js
/i18n/sv.js
/i18n/no.js
/i18n/da.js
