# Standard exclusions
node_modules/
dist/
*.local
.env
.env.*
!.env.example
!**/.env.example
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# IBV framework lives at user-level (~/.claude/, ~/.specify/)
# Exclude framework debris but keep the project's IBV connector files
# and shared skills (replayable SOPs that survive machine wipes)
.claude/*
!.claude/settings.json
!.claude/skills/
.specify/

# Specs live in Z:\keeply-blog (separate git repo on NAS)
specs/

# IBV runtime state (per-machine, never share)
.metrics/

# Local PRD drafts and brainstorming
0.idea/

# Local debug notes (per-incident scratch, not for commit)
debug/

# Playwright MCP cache
.playwright-mcp/

# Hugo build output
public/
resources/_gen/
.hugo_build.lock

# Tailwind compiled CSS — regenerated by `npm run css:build` (CI runs this
# before Hugo). Hugo fingerprints it with SRI so the final asset lives in
# public/ with a hash suffix.
/assets/css/style.css

# Hugo stats (writeStats = true generates these)
hugo_stats.json
assets/jsconfig.json

# Python bytecode (BWF lint scripts)
__pycache__/
*.pyc
static/fonts/_full-backup/

# SEO audit output (local runs of `npm run seo:audit`; CI uses /tmp)
_dev/seo/audit-output/
_dev/seo/serpbear/data/
