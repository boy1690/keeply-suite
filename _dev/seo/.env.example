# Cloudflare cache purge credentials for cf-purge.js.
# Copy this file to .env (gitignored) and fill in real values.
#
# CF_PURGE_TOKEN
#   API token scoped to "Zone.Cache Purge" only on the keeply.work zone.
#   Create at: https://dash.cloudflare.com/profile/api-tokens
#   Template: Custom token → Permissions: Zone → Cache Purge → Purge
#             Zone Resources: Include → Specific zone → keeply.work
#
# CF_ZONE_ID
#   The zone ID for keeply.work. Found at:
#   https://dash.cloudflare.com → keeply.work overview → Zone ID (right column)
#   Note: blog.keeply.work shares this same zone (apex = keeply.work).
CF_PURGE_TOKEN=
CF_ZONE_ID=
