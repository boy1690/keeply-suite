# SerpBear configuration — copy to `.env` next to docker-compose.yml
# `.env` is gitignored by repo-root .gitignore (`.env` rule).

# --- Required ---
SERPBEAR_USER=admin
SERPBEAR_PASSWORD=change-me-strong-password
SERPBEAR_SECRET=replace-with-32-char-random-string-aaa
SERPBEAR_APIKEY=replace-with-32-char-random-string-bbb

# Port on the host (container always listens on 3000 internally)
SERPBEAR_PORT=3001

# Public URL — used in email links + CORS. Set to a tailscale / LAN / public
# URL if you reach it from another machine.
SERPBEAR_PUBLIC_URL=http://localhost:3001

# --- Optional: email notifications ---
# SERPBEAR_SMTP_HOST=smtp.gmail.com
# SERPBEAR_SMTP_PORT=587
# SERPBEAR_SMTP_USER=you@example.com
# SERPBEAR_SMTP_PASS=app-password-here
# SERPBEAR_EMAIL_FROM=you@example.com

# --- Optional: Google Search Console integration ---
# Create a service account in GCP, download the JSON key, add the service
# account email as a User in GSC (Full or Restricted), then paste below.
# SERPBEAR_GSC_CLIENT_EMAIL=keeply-serpbear@project-id.iam.gserviceaccount.com
# SERPBEAR_GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
