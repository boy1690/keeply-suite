{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- /*
  Multilingual sitemap index. Emits entries for core 6 locales + curated market
  locales that ship native (non-MT) articles.
  Blanket auto-translate locales (es / fr / pt / ru / nl / pl / tr / vi / th / id / ar / hi)
  still build per-locale sitemap.xml files but are NOT linked here, so Google
  doesn't crawl them as part of the canonical sitemap submission (per R1, spec
  seo-indexability-l2 FR-002).
  EXCEPTION: de + es + pt added 2026-05-22 — country-specific concentrated-publishing
  pilots with hand-written native articles (de: excel-nicht-gespeicherte-datei-...;
  es: recuperar-archivo-excel-no-guardado; pt: recuperar-documento-word-nao-salvo);
  real indexable pages, not MT, so they belong in the canonical sitemap. When pl/tr
  ship their native pilots, add them too.
*/ -}}
{{- $coreLocales := slice "en" "zh-tw" "zh-cn" "ja" "ko" "it" "de" "es" "pt-br" "pl" "tr" "fr" "th" "vi" -}}
{{- range . -}}
  {{- if in $coreLocales .Language.Lang }}
  <sitemap>
    <loc>{{ .SitemapAbsURL }}</loc>{{ if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>{{ end }}
  </sitemap>
  {{- end -}}
{{- end }}
</sitemapindex>
