{
  "name": "keeply-blog",
  "private": true,
  "description": "Keeply Blog — Hugo static site with Tailwind CSS styling aligned to keeply-website",
  "scripts": {
    "css:build": "tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --minify",
    "css:watch": "tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --watch",
    "dev": "hugo server -D",
    "build": "npm run css:build && hugo --gc --minify",
    "seo:fetch:gsc": "node _dev/seo/fetch-gsc.js",
    "seo:fetch:bwt": "node _dev/seo/fetch-bwt.js",
    "seo:fetch:yandex": "node _dev/seo/fetch-yandex.js",
    "seo:fetch:ga4": "node _dev/seo/fetch-ga4.js",
    "seo:health": "node _dev/seo/health-check.js",
    "seo:report": "node _dev/seo/build-report.js",
    "seo:audit": "npx --yes site-audit-seo@latest -u https://blog.keeply.work/ --lighthouse --json --csv --xlsx --max-requests 200 --out-dir _dev/seo/audit-output --no-color"
  },
  "devDependencies": {
    "googleapis": "^144.0.0",
    "tailwindcss": "^3.4.19"
  }
}
